  <property name="styleSheet">
   <string notr="true">/* Bo góc và làm mịn ô nhập liệu */
QLineEdit {
    border: 1px solid #ccc;
    border-radius: 8px;
    padding: 10px;
    background: white;
}
/* Đổi màu viền khi click vào ô */
QLineEdit:focus {
    border: 2px solid #795548;
}

/* Làm nút Sign in chuyên nghiệp */
QPushButton {
    background-color: #795548;
    color: white;
    border-radius: 8px;
    min-height: 40px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #5D4037;
}

/* Nút Sign up dạng link xanh */
#label_signup, QPushButton#pushButton_signup {
    color: #007bff;
    background: transparent;
    border: none;
}
/* Tiêu đề */
QLabel#label_title {
    font-size: 20px;
    color: #4E342E;
    font-weight: bold;
}

/* Các ô nhập liệu to và đẹp */
QLineEdit {
    border: 1px solid #bdc3c7;
    border-radius: 5px;
    padding: 8px;
    min-height: 35px; /* Làm ô to ra */
    background-color: #ffffff;
}

/* Nút Sign in chính */
QPushButton#btn_login { 
    background-color: #795548;
    color: white;
    border-radius: 5px;
    min-height: 40px;
    font-weight: bold;
}

/* Nút Sign up nhỏ phía dưới */
#btn_signup {
    background-color: transparent;
    border: none;
    color: #5D4037;
    font-size: 12px;
    text-decoration: underline;
}</string>
