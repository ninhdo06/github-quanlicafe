        <property name="styleSheet">
         <string notr="true">/* Chỉnh font chữ cho tiêu đề Tab */
QTabBar::tab {
    font-size: 18px;          /* Tăng kích cỡ chữ lên 18px */
    font-weight: bold;        /* Làm đậm chữ */
    height: 50px;             /* Chỉnh chiều cao của thanh Tab */
    width: 200px;             /* Chỉnh độ rộng cố định để các tab bằng nhau */
    min-width: 150px;         /* Đảm bảo độ rộng tối thiểu */
}

/* Hiệu ứng khi chọn vào Tab (để giữ màu nâu bạn đang có) */
QTabBar::tab:selected {
    background: #7d5a44;      /* Màu nâu giống trong hình của bạn */
    color: white;             /* Màu chữ khi chọn */
}</string>
