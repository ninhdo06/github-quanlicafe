        <property name="styleSheet">
         <string notr="true">/* Chỉnh font chữ cho tiêu đề Tab */
QTabBar::tab {
    font-size: 18px;          /* Tăng kích cỡ chữ lên 18px */
    font-weight: bold;        /* Làm đậm chữ */
    height: 50px;             /* Chỉnh chiều cao của thanh Tab */
    width: 200px;             /* Chỉnh độ rộng cố định để các tab bằng nhau */
    min-width: 150px;         /* Đảm bảo độ rộng tối thiểu */
}

/* Hiệu ứng khi chọn vào Tab (để giữ màu nâu bạn đang có) */
QTabBar::tab:selected {
    background: #7d5a44;      /* Màu nâu giống trong hình của bạn */
    color: white;             /* Màu chữ khi chọn */
}</string>
        </property>
        <property name="currentIndex">
         <number>0</number>
        </property>
        <widget class="QWidget" name="tab_4">
         <property name="styleSheet">
          <string notr="true">
    QMainWindow { background-color: #F8F5F2; }
    /* Nút món ăn */
    #menuGrid QPushButton { 
        background-color: #FFFFFF; 
        border: 1px solid #E0D7D0; 
        border-radius: 12px; 
        padding: 10px;
        min-width: 180px;
        min-height: 220px;
    }
    #menuGrid QPushButton:hover { background-color: #FDFCFB; border-color: #8C6A4B; }
    
    /* Bảng hóa đơn */
    QTableWidget { 
        background-color: white; 
        border: 1px solid #D7D2CB; 
        border-radius: 8px; 
        gridline-color: #F1EFEA;
        font-size: 13px;
    }
    QHeaderView::section { 
        background-color: #8C6A4B; 
        color: white; 
        font-weight: bold; 
        padding: 8px; 
        border: none;
    }
    
    /* Nút chức năng */
    #btnExit { background-color: #E63946; color: white; font-weight: bold; border-radius: 8px; min-height: 45px; }
    #btnPayment { background-color: #588157; color: white; font-size: 18px; font-weight: bold; border-radius: 10px; min-height: 60px; border: none; }
    #btnPayment:hover { background-color: #3A5A40; }
QFrame#ProductCard {
    background-color: white;
    border-radius: 15px;
    border: 1px solid #E0E0E0;
}

QFrame#ProductCard:hover {
    border: 2px solid #2D5A27;
    background-color: #FAFAFA;
}

QLabel#PriceLabel {
    color: #2D5A27;
    font-weight: bold;
    font-size: 14px;
}
/* Thiết lập nền cho toàn bộ cửa sổ */
QMainWindow {
    background-color: #FDF5E6; /* Màu nền phụ - Trắng kem */
}

/* Kiểu dáng cho các ô sản phẩm (Widget) */
.ProductCard {
    background-color: #603913; /* Màu nền chính - Nâu */
    border-radius: 10px;        /* Bo góc cho thân thiện */
    padding: 10px;
}

/* Kiểu dáng cho tên sản phẩm */
.ProductTitle {
    color: #FFFFFF;             /* Màu chữ chính - Trắng */
    font-weight: bold;
    font-size: 14px;
}

/* Kiểu dáng cho giá sản phẩm */
.ProductPrice {
    color: #D9CAB3;             /* Màu chữ phụ - Kem nhạt */
    font-size: 12px;
}

/* Hiệu ứng khi di chuột qua ô sản phẩm */
.ProductCard:hover {
    background-color: #4F2F0F; /* Màu điểm nhấn - Nâu đậm hơn */
}

/* Kiểu dáng cho nút thanh toán */
QPushButton#checkoutButton {
    background-color: #4CAF50; /* Hoặc #A0522D tùy chọn */
    color: white;
    border-radius: 5px;
    padding: 10px 20px;
    font-weight: bold;
}
