  <property name="styleSheet">
   <string notr="true">/* Tổng thể cửa sổ */
QMainWindow {
    background-color: #f5f5f5;
}

/* TabBar - Thanh menu danh mục (Cà phê, Trà...) */
QTabBar::tab {
    background: #ffffff;
    border: 1px solid #dcdcdc;
    padding: 10px 20px;
    margin-right: 2px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    color: #5d4037;
    font-weight: bold;
}

QTabBar::tab:selected {
    background: #6f4e37; /* Màu cà phê */
    color: white;
    border-bottom-color: #6f4e37;
}

QTabBar::tab:hover {
    background: #efebe9;
}

/* Card sản phẩm (Dựa trên QFrame hoặc QWidget chứa ảnh/tên) */
/* Giả sử mỗi item là một QFrame */
#productCard {
    background-color: white;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
}

#productCard:hover {
    border: 2px solid #6f4e37;
    background-color: #fafafa;
}

/* Nhãn tên sản phẩm và giá */
QLabel {
    color: #3e2723;
    font-family: &quot;Segoe UI&quot;, sans-serif;
}

#priceLabel {
    color: #8d6e63;
    font-weight: bold;
}

/* Khu vực hóa đơn (Bên phải) */
QTableWidget {
    background-color: white;
    border-radius: 10px;
    gridline-color: #f0f0f0;
    selection-background-color: #d7ccc8;
}

QHeaderView::section {
    background-color: #6f4e37;
    color: white;
    padding: 5px;
    border: none;
    font-weight: bold;
}

/* Nút Thanh Toán */
QPushButton#payButton {
    background-color: #6f4e37;
    color: white;
    border-radius: 8px;
    padding: 10px;
    font-size: 14px;
    font-weight: bold;
}

QPushButton#payButton:hover {
    background-color: #5d4037;
}

QPushButton#payButton:pressed {
    background-color: #3e2723;
}

/* Tổng cộng */
#totalLabel {
    font-size: 18px;
    font-weight: bold;
    color: #d32f2f; /* Màu đỏ nổi bật cho tiền */
}
/* Tăng kích thước các tab */
QTabBar::tab {
    background: #f8f9fa;
    border: 1px solid #d1d1d1;
    border-bottom: none;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    
    /* Chỉnh kích thước ở đây */
    min-width: 130px;  /* Độ dài tối thiểu của mỗi tab */
    min-height: 40px;  /* Chiều cao của tab */
    padding: 5px 20px; /* Khoảng cách chữ bên trong */
    font-size: 14px;   /* Cỡ chữ to hơn */
    margin-right: 4px;
}

/* Màu sắc khi tab được chọn */
QTabBar::tab:selected {
    background-color: #6f4e37; /* Màu nâu cà phê */
    color: white;
    font-weight: bold;
    border: 1px solid #6f4e37;
}

/* Hiệu ứng khi di chuột qua tab */
QTabBar::tab:hover:!selected {
    background-color: #e0e0e0;
}
/* Giả sử Object Name của nút là btn_pay hoặc tương tự */
/* Bạn có thể thay đổi tên ID sau dấu # cho đúng với tên bạn đặt trong Qt Designer */

QPushButton#btn_pay {
    background-color: #26a69a; /* Màu xanh Teal hiện đại */
    color: white;
    border-radius: 6px;
    font-size: 16px;
    font-weight: bold;
    padding: 12px;
    border: none;
}

QPushButton#btn_pay:hover {
    background-color: #2bbbad; /* Sáng hơn khi di chuột */
}

QPushButton#btn_pay:pressed {
    background-color: #00695c; /* Đậm hơn khi click */
}</string>
  </property>
